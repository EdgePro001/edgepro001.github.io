---
const name = "Junxian Ma";
const tagline = "Interested in Machine Learning & Artificial Intelligence";
const bio = "CS student at Tsinghua University. Passionate about building intelligent systems.";

const links = [
  { label: "GitHub", href: "https://github.com/EdgePro001" },
  { label: "Email", href: "mailto:junxianma93@gmail.com" },
];

const projects: { name: string; desc: string; href: string; tags: string[] }[] = [];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={`${name} — ${tagline}`} />
    <title>{name}</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #0f0f0f;
        color: #e8e8e8;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 4rem 1.5rem;
        line-height: 1.6;
      }

      main {
        width: 100%;
        max-width: 640px;
      }

      /* Hero */
      .hero { margin-bottom: 3rem; }
      .hero h1 { font-size: 2rem; font-weight: 700; letter-spacing: -0.5px; margin-bottom: 0.4rem; }
      .hero .tagline { color: #888; font-size: 1rem; margin-bottom: 1rem; }
      .hero .bio { color: #bbb; font-size: 0.95rem; max-width: 480px; }

      /* Links */
      .links { display: flex; gap: 1rem; margin-top: 1.5rem; flex-wrap: wrap; }
      .links a {
        color: #e8e8e8;
        text-decoration: none;
        font-size: 0.9rem;
        border-bottom: 1px solid #444;
        padding-bottom: 1px;
        transition: border-color 0.2s, color 0.2s;
      }
      .links a:hover { color: #fff; border-color: #fff; }

      /* Section */
      section { margin-bottom: 2.5rem; }
      section h2 {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: #555;
        margin-bottom: 1.2rem;
      }

      /* Projects */
      .projects { display: flex; flex-direction: column; gap: 1.2rem; }
      .project a {
        text-decoration: none;
        color: inherit;
        display: block;
        padding: 1rem 1.2rem;
        border: 1px solid #222;
        border-radius: 8px;
        transition: border-color 0.2s, background 0.2s;
      }
      .project a:hover { border-color: #444; background: #161616; }
      .project .proj-name { font-weight: 600; font-size: 0.95rem; margin-bottom: 0.3rem; }
      .project .proj-desc { color: #888; font-size: 0.875rem; margin-bottom: 0.6rem; }
      .project .tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }
      .project .tag {
        font-size: 0.75rem;
        color: #666;
        background: #1a1a1a;
        border: 1px solid #2a2a2a;
        border-radius: 4px;
        padding: 0.1rem 0.5rem;
      }

      footer {
        margin-top: auto;
        padding-top: 3rem;
        color: #444;
        font-size: 0.8rem;
      }
    </style>
  </head>
  <body>
    <main>
      <div class="hero">
        <h1>{name}</h1>
        <p class="tagline">{tagline}</p>
        <p class="bio">{bio}</p>
        <nav class="links">
          {links.map(link => <a href={link.href} target="_blank" rel="noopener">{link.label}</a>)}
        </nav>
      </div>

      {projects.length > 0 && (
        <section>
          <h2>Projects</h2>
          <div class="projects">
            {projects.map(p => (
              <div class="project">
                <a href={p.href} target="_blank" rel="noopener">
                  <div class="proj-name">{p.name}</div>
                  <div class="proj-desc">{p.desc}</div>
                  <div class="tags">
                    {p.tags.map(t => <span class="tag">{t}</span>)}
                  </div>
                </a>
              </div>
            ))}
          </div>
        </section>
      )}
    </main>

    <footer>© {new Date().getFullYear()} {name}</footer>
  </body>
</html>
