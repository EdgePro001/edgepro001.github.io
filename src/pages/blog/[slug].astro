---
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const includeDrafts = import.meta.env.DEV;
  const posts = (await getCollection("blog")).filter((post) => includeDrafts || !post.data.draft);

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const includeDrafts = import.meta.env.DEV;
const allPosts = (await getCollection("blog")).filter((entry) => includeDrafts || !entry.data.draft);
const translationKey = post.data.translationKey ?? post.id;
const translations = allPosts.filter(
  (entry) =>
    entry.id !== post.id &&
    (entry.data.translationKey ?? entry.id) === translationKey
);

const languageLabel = (lang: "en" | "zh") => (lang === "zh" ? "中文" : "English");

const formatDate = (date: Date) =>
  date.toLocaleDateString("en", {
    year: "numeric",
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });
---

<!doctype html>
<html lang={post.data.lang === "zh" ? "zh-CN" : "en"}>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content={post.data.description}>
    <title>{post.data.title} - Junxian Ma</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="stylesheet" href="/styles.css?v=8">
  </head>
  <body>
    <main class="container post" aria-label={post.data.title}>
      <p>
        <a href="/">Junxian Ma</a> / <a href="/blog/">Writings</a>
      </p>

      <header class="post-header">
        <h1>{post.data.title}</h1>
        <p class="muted">
          {formatDate(post.data.date)}
          <span class="language-tag">{languageLabel(post.data.lang)}</span>
          {post.data.draft && <span class="draft-tag">Draft</span>}
        </p>
        {translations.length > 0 && (
          <p>
            Also available in
            {translations.map((entry, index) => (
              <>
                {index > 0 && " / "}
                <a href={`/blog/${entry.id}/`}>{languageLabel(entry.data.lang)}</a>
              </>
            ))}
          </p>
        )}
      </header>

      <Content />
    </main>

    <button class="theme-toggle" type="button" aria-label="Toggle color mode">Mode</button>
    <script is:inline src="/script.js?v=7"></script>
  </body>
</html>
