---
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter((post) => !post.data.draft);

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formatDate = (date: Date) =>
  date.toLocaleDateString("en", {
    year: "numeric",
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content={post.data.description}>
    <title>{post.data.title} - Junxian Ma</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="stylesheet" href="/styles.css?v=8">
  </head>
  <body>
    <main class="container post" aria-label={post.data.title}>
      <p>
        <a href="/">Junxian Ma</a> / <a href="/blog/">Writings</a>
      </p>

      <header class="post-header">
        <h1>{post.data.title}</h1>
        <p class="muted">{formatDate(post.data.date)}</p>
      </header>

      <Content />
    </main>

    <button class="theme-toggle" type="button" aria-label="Toggle color mode">Mode</button>
    <script is:inline src="/script.js?v=7"></script>
  </body>
</html>
